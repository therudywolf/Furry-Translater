    ; ═══════════════════════════════════════════════════════════
    ; ОСНОВНАЯ ФУНКЦИЯ ТРАНСФОРМАЦИИ
    ; ═══════════════════════════════════════════════════════════
    
    ; Главная функция трансформации текста
    ; Алгоритм:
    ;   1. Проверяет, активен ли конвертер и не в черном списке ли приложение
    ;   2. Сохраняет текущий буфер обмена
    ;   3. Копирует выделенный текст (Ctrl+C)
    ;   4. Если текст выделен - трансформирует его
    ;   5. Если текст не выделен - трансформирует последнее слово
    ;   6. Вставляет трансформированный текст (Ctrl+V)
    ;   7. Восстанавливает исходный буфер обмена
    static UwuTransform() {
        ; Проверка активности и черного списка
        if !this.isActive || this.IsBlacklisted()
            return
        
        ; Сохраняем текущий буфер обмена для последующего восстановления
        oldClip := A_Clipboard
        A_Clipboard := ""
        
        ; Пытаемся скопировать выделенный текст
        ; Send("^c") отправляет комбинацию Ctrl+C
        Send("^c")
        
        ; Ожидаем появления текста в буфере обмена (максимум 0.5 секунды)
        if !ClipWait(0.5) {
            ; Если ничего не выделено - трансформируем последнее слово
            ; Это альтернативный режим работы
            this.TransformLastWord()
            return
        }
        
        ; Получаем текст из буфера обмена
        text := A_Clipboard
        
        ; Если текст пустой, восстанавливаем буфер и выходим
        if text = "" {
            A_Clipboard := oldClip
            return
        }
        
        ; Применяем трансформацию к тексту
        transformed := this.ProcessText(text)
        
        ; Вставляем трансформированный текст
        A_Clipboard := transformed
        Send("^v")
        
        ; Задержка из конфигурации
        Sleep(this.insertDelay)
        
        ; Восстанавливаем исходный буфер обмена
        A_Clipboard := oldClip
    }
    
    ; Трансформация последнего слова (альтернативный режим)
    ; Используется, когда пользователь нажал Ctrl+Shift+U без выделения текста
    ; Алгоритм:
    ;   1. Выделяет последнее слово (Ctrl+Shift+Left)
    ;   2. Копирует его
    ;   3. Трансформирует
    ;   4. Вставляет обратно
    static TransformLastWord() {
        ; Выделяем последнее слово (от курсора влево до пробела)
        Send("^+{Left}")
        Sleep(this.copyDelay)  ; Задержка из конфигурации
        
        ; Сохраняем буфер обмена
        oldClip := A_Clipboard
        A_Clipboard := ""
        
        ; Копируем выделенное слово
        Send("^c")
        
        ; Ожидаем появления текста в буфере
        if !ClipWait(0.3)
            return
        
        ; Получаем слово и трансформируем
        word := A_Clipboard
        transformed := this.ProcessText(word)
        
        ; Вставляем трансформированное слово
        A_Clipboard := transformed
        Send("^v")
        
        ; Восстанавливаем буфер обмена
        Sleep(this.insertDelay)
        A_Clipboard := oldClip
    }
    
    
    ; ═══════════════════════════════════════════════════════════
    ; ОБРАБОТКА ТЕКСТА
    ; ═══════════════════════════════════════════════════════════
    
    ; Основная функция обработки текста
    ; Применяет все трансформации в правильном порядке:
    ;   1. Словарные замены (приоритет)
    ;   2. Фонетические мутации (если интенсивность >= 3)
    ;   3. Добавление фразочек (количество зависит от интенсивности)
    ;
    ; Args:
    ;   text - исходный текст для трансформации
    ;
    ; Returns:
    ;   Трансформированный текст в uwu-стиле
    static ProcessText(text) {
        ; Если текст пустой, возвращаем как есть
        if text = ""
            return text
        
        result := text
        
        ; ШАГ 1: ТОЧНЫЕ ЗАМЕНЫ СЛОВ (регистронезависимо)
        ; Проходим по всему словарю и заменяем слова
        ; Используем \b для границ слов, чтобы не заменять части слов
        ; Флаг "i" делает замену регистронезависимой
        for original, replacement in this.wordsRu {
            ; RegExReplace выполняет замену с использованием регулярных выражений
            ; Паттерн: \b - граница слова, original - исходное слово, \b - граница слова
            result := RegExReplace(result, "i)\b" original "\b", replacement)
        }
        
        ; ШАГ 2: ФОНЕТИЧЕСКИЕ МУТАЦИИ
        ; Применяются только если интенсивность >= 3
        ; Фонетика искажает звуки для создания милого эффекта
        if this.intensity >= 3 {
            result := this.ApplyPhonetics(result)
        }
        
        ; ШАГ 3: ДОБАВЛЕНИЕ ФРАЗОЧЕК
        ; Добавляем фразочки только если включено в настройках
        if this.addPhrases {
            ; Количество фразочек зависит от интенсивности
            phraseCount := this.GetPhraseCount()
            Loop phraseCount {
                ; Случайно выбираем фразочку из массива
                phrase := this.phrases[Random(1, this.phrases.Length)]
                ; Добавляем в конец текста
                result .= phrase
            }
        }
        
        return result
    }
    
    ; Применение фонетических мутаций к тексту
    ; Правила зависят от уровня интенсивности:
    ;   - >= 3: базовая фонетика (р->ль, л->ль)
    ;   - >= 5: средняя фонетика (ов->ув)
    ;   - >= 7: максимальная фонетика (удлинение гласных)
    ;
    ; Args:
    ;   text - текст после словарных замен
    ;
    ; Returns:
    ;   Текст с примененными фонетическими мутациями
    static ApplyPhonetics(text) {
        ; БАЗОВАЯ ФОНЕТИКА (intensity >= 3)
        ; Замена 'р' и 'л' на 'ль' (мягкое произношение)
        ; Паттерн: ([^а-яА-ЯёЁ]) - не русская буква, р/л - буква для замены
        ; Это предотвращает замену внутри русских слов, где это не нужно
        text := RegExReplace(text, "([^а-яА-ЯёЁ])р", "$1ль")
        text := RegExReplace(text, "([^а-яА-ЯёЁ])Р", "$1Ль")
        text := RegExReplace(text, "([^а-яА-ЯёЁ])л", "$1ль")
        text := RegExReplace(text, "([^а-яА-ЯёЁ])Л", "$1Ль")
        
        ; СРЕДНЯЯ ФОНЕТИКА (intensity >= 5)
        ; Замена "ов" на "ув" для более милого звучания
        if this.intensity >= 5 {
            text := StrReplace(text, "ов", "ув")
            text := StrReplace(text, "Ов", "Ув")
        }
        
        ; МАКСИМАЛЬНАЯ ФОНЕТИКА (intensity >= 7)
        ; Удлинение гласных для максимальной милоты
        ; Паттерн: ([аеиоуыэюя]) - любая гласная, заменяем на удвоенную
        if this.intensity >= 7 {
            text := RegExReplace(text, "([аеиоуыэюя])", "$1$1")
        }
        
        return text
    }
    
    ; Определение количества фразочек для добавления
    ; Зависит от уровня интенсивности:
    ;   - <= 3: 0-1 фраза (минимальная милота)
    ;   - 4-6: 1-2 фразы (средняя милота)
    ;   - >= 7: 2-3 фразы (максимальная милота)
    ;
    ; Returns:
    ;   Количество фразочек для добавления
    static GetPhraseCount() {
        if this.intensity <= 3
            return Random(0, 1)      ; 0-1 фраза
        else if this.intensity <= 6
            return Random(1, 2)      ; 1-2 фразы
        else
            return Random(2, 3)      ; 2-3 фразы
    }
    
    
    ; ═══════════════════════════════════════════════════════════
    ; ВСПОМОГАТЕЛЬНЫЕ ФУНКЦИИ
    ; ═══════════════════════════════════════════════════════════
    
    ; Проверка, находится ли текущее приложение в черном списке
    ; Используется для предотвращения трансформации в чувствительных местах
    ; (пароли, терминалы и т.д.)
    ;
    ; Returns:
    ;   true - если приложение в черном списке
    ;   false - если приложение разрешено
    static IsBlacklisted() {
        try {
            ; Получаем имя процесса активного окна
            proc := WinGetProcessName("A")
            
            ; Проверяем, содержится ли имя процесса в черном списке
            for app in this.blacklist {
                if InStr(proc, app)
                    return true
            }
        }
        ; В случае ошибки разрешаем трансформацию (безопаснее)
        return false
    }
    
    ; Изменение интенсивности трансформации
    ; Открывает диалог для ввода значения от 1 до 10
    static ChangeIntensity() {
        ; Создаем диалог ввода
        ; Параметры: подсказка, заголовок, размеры, значение по умолчанию
        ib := InputBox("Уровень милоты (1-10):", "Интенсивность", "w200 h100", this.intensity)
        
        ; Если пользователь нажал OK
        if ib.Result = "OK" {
            ; Преобразуем введенное значение в число
            value := Integer(ib.Value)
            
            ; Проверяем, что значение в допустимом диапазоне
            if value >= 1 && value <= 10 {
                ; Устанавливаем новую интенсивность
                this.intensity := value
                
                ; Показываем уведомление
                this.ShowNotification("Интенсивность: " value "/10")
            }
        }
    }
    
    ; Переключение паузы/возобновления работы
    ; Временно отключает или включает трансформацию
    static TogglePause() {
        ; Инвертируем флаг активности
        this.isActive := !this.isActive
        
        ; Формируем сообщение о статусе
        status := this.isActive ? "Включен 🐺" : "Пауза ⏸"
        
        ; Показываем уведомление
        this.ShowNotification(status)
    }
    
    ; Показ справки по использованию
    ; Отображает окно с инструкциями и текущими настройками
    static ShowHelp() {
        ; Формируем текст справки
        help := "
        (
        🐺 ВОЛЧИЙ UWU CONVERTER v3.0
        
        КАК ИСПОЛЬЗОВАТЬ:
        1. Печатаешь текст нормально (видишь что пишешь)
        2. Выделяешь текст → Ctrl+Shift+U
        3. Текст превращается в uwu-версию!
        
        АЛЬТЕРНАТИВНО:
        - Ctrl+Shift+U БЕЗ выделения = uwu последнего слова
        
        ДРУГИЕ КЛАВИШИ:
        - Ctrl+Shift+I = Интенсивность (1-10)
        - Ctrl+Shift+P = Пауза/Включить
        - Ctrl+Shift+H = Эта справка
        
        ИНТЕНСИВНОСТЬ: )" . this.intensity . "/10
        СТАТУС: " . (this.isActive ? "Работает" : "Пауза") . "
        
        СЛОВАРЬ: 400+ волчьих слов + мат
        ФРАЗОЧКИ: 40+ ролок-эмоций
        )"
        
        ; Показываем окно сообщения
        ; Параметры: текст, заголовок, тип (i = информация)
        MsgBox(help, "Справка", "Iconi")
    }
    
    ; Показ приветственного сообщения при запуске
    static ShowWelcome() {
        this.ShowNotification("🐺 Волчий конвертер v3.0 готов!`nВыдели текст → Ctrl+Shift+U", 3000)
    }
    
    ; Показ уведомления (tooltip)
    ; Отображает временное сообщение в углу экрана
    ;
    ; Args:
    ;   text - текст уведомления
    ;   duration - длительность отображения в миллисекундах (по умолчанию 2000)
    static ShowNotification(text, duration := 2000) {
        ; Показываем tooltip с текстом
        ToolTip(text)
        
        ; Устанавливаем таймер для скрытия tooltip через указанное время
        ; Отрицательное значение означает однократное выполнение
        SetTimer(() => ToolTip(), -duration)
    }
    
    ; Настройка иконки в системном трее
    ; Создает контекстное меню для управления приложением
    static SetupTrayIcon() {
        ; Устанавливаем подсказку для иконки
        A_IconTip := "🐺 UWU Converter v3.0"
        
        ; Получаем объект меню трея
        tray := A_TrayMenu
        
        ; Очищаем меню (удаляем стандартные пункты)
        tray.Delete()
        
        ; Добавляем пункты меню
        tray.Add("Интенсивность", (*) => this.ChangeIntensity())
        tray.Add("Пауза", (*) => this.TogglePause())
        tray.Add()  ; Разделитель
        tray.Add("Справка", (*) => this.ShowHelp())
        tray.Add("Выход", (*) => ExitApp())
    }

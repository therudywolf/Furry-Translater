    ; ИНИЦИАЛИЗАЦИЯ
    ; ═══════════════════════════════════════════════════════════
    
    ; Конструктор класса - вызывается автоматически при создании экземпляра
    static __New() {
        ; Загружаем конфигурацию из config.ini
        this.LoadConfig()
        
        ; Загружаем словарь замен
        this.LoadDictionary()
        
        ; Загружаем массив фразочек
        this.LoadPhrases()
        
        ; Настраиваем горячие клавиши
        this.SetupHotkeys()
        
        ; Настраиваем иконку в трее
        this.SetupTrayIcon()
        
        ; Показываем приветственное сообщение
        this.ShowWelcome()
    }
    
    ; ═══════════════════════════════════════════════════════════
    ; ЗАГРУЗКА КОНФИГУРАЦИИ
    ; ═══════════════════════════════════════════════════════════
    
    ; Загрузка настроек из config.ini
    ; Если файл не существует или параметр не найден, используются значения по умолчанию
    static LoadConfig() {
        configFile := A_ScriptDir "\config.ini"
        
        ; Загружаем настройки из секции [Settings]
        ; Интенсивность
        this.intensity := IniRead(configFile, "Settings", "Intensity", "5")
        try {
            this.intensity := Integer(this.intensity)
            if this.intensity < 1 || this.intensity > 10
                this.intensity := 5
        } catch {
            this.intensity := 5
        }
        
        ; Режим работы (пока не используется, зарезервировано)
        mode := IniRead(configFile, "Settings", "Mode", "1")
        
        ; Автоматическая фонетика
        autoPhonetics := IniRead(configFile, "Settings", "AutoPhonetics", "true")
        ; (используется через проверку intensity >= 3)
        
        ; Добавление фразочек
        addPhrases := IniRead(configFile, "Settings", "AddPhrases", "true")
        this.addPhrases := (addPhrases = "true" || addPhrases = "1")
        
        ; Вероятность фразочек (пока не используется напрямую, влияет через GetPhraseCount)
        phraseProb := IniRead(configFile, "Settings", "PhraseProbability", "0.6")
        try {
            this.phraseProbability := Float(phraseProb)
            if this.phraseProbability < 0.0 || this.phraseProbability > 1.0
                this.phraseProbability := 0.6
        } catch {
            this.phraseProbability := 0.6
        }
        
        ; Загружаем горячие клавиши из секции [Hotkeys]
        this.hotkeyTransform := IniRead(configFile, "Hotkeys", "Transform", "^+u")
        this.hotkeyIntensity := IniRead(configFile, "Hotkeys", "Intensity", "^+i")
        this.hotkeyPause := IniRead(configFile, "Hotkeys", "Pause", "^+p")
        this.hotkeyHelp := IniRead(configFile, "Hotkeys", "Help", "^+h")
        
        ; Загружаем черный список из секции [Blacklist]
        blacklistStr := IniRead(configFile, "Blacklist", "Apps", "KeePass,cmd.exe,powershell,WindowsTerminal,Code.exe")
        ; Разделяем строку по запятым и создаем массив
        this.blacklist := []
        Loop Parse, blacklistStr, "," {
            appName := Trim(A_LoopField)
            if appName != ""
                this.blacklist.Push(appName)
        }
        
        ; Загружаем задержки из секции [Advanced]
        insertDelay := IniRead(configFile, "Advanced", "InsertDelay", "100")
        try {
            this.insertDelay := Integer(insertDelay)
        } catch {
            this.insertDelay := 100
        }
        
        copyDelay := IniRead(configFile, "Advanced", "CopyDelay", "50")
        try {
            this.copyDelay := Integer(copyDelay)
        } catch {
            this.copyDelay := 50
        }
    }
    
    

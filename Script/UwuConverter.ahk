    ; Регистрация всех горячих клавиш приложения
    static SetupHotkeys() {
        ; Ctrl+Shift+U - главная функция трансформации
        ; Выделяешь текст → нажимаешь → получаешь uwu-версию
        HotKey("^+u", (*) => this.UwuTransform())
        
        ; Ctrl+Shift+I - изменение интенсивности трансформации
        ; Открывает диалог для ввода значения от 1 до 10
        HotKey("^+i", (*) => this.ChangeIntensity())
        
        ; Ctrl+Shift+P - пауза/возобновление работы
        ; Временно отключает трансформацию
        HotKey("^+p", (*) => this.TogglePause())
        
        ; Ctrl+Shift+H - показ справки
        ; Отображает окно с инструкциями
        HotKey("^+h", (*) => this.ShowHelp())

    ;   - Применение фонетических правил (>= 3)
    ;   - Количество добавляемых фразочек
    ;   - Степень искажения текста (>= 5, >= 7)
    static intensity := 5
    
    ; Флаг активности конвертера
    ; Если false, трансформация не выполняется
    static isActive := true
    
    ; Словарь точных замен слов
    ; Формат: Map("оригинальное_слово", "милая_версия")
    static wordsRu := Map()
    
    ; Массив фразочек-эмоций (добавляются случайно в конец текста)
    ; Примеры: " гав~", " *виляет хвостиком*", " OwO"
    static phrases := []
    
    ; Черный список приложений, где трансформация отключена
    ; Полезно для паролей, терминалов и других чувствительных мест
    static blacklist := ["KeePass", "cmd.exe", "powershell", "WindowsTerminal", "Code.exe"]
    
    

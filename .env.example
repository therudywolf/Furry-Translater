# ───────────────────────────────────────────────────────────────
# LLM backend for the Web AI chat (OpenAI-compatible: LM Studio, Ollama, ...)
# ───────────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values:
#     cp .env.example .env
# .env is gitignored — NEVER commit it. The key lives only here and is
# injected into requests server-side by the nginx proxy, so it never
# reaches the browser.

# Upstream LLM base URL, WITHOUT the trailing /v1.
# Example (LM Studio behind a reverse proxy): https://lmstudio.example.com
LLM_UPSTREAM=https://your-lmstudio-host.example

# API token. Sent to the upstream as:  Authorization: Bearer <token>
# LM Studio auth: https://lmstudio.ai/docs/developer/core/authentication
LLM_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx

# Model id to request. Must exist on the upstream (list with GET /v1/models).
LLM_MODEL=google/gemma-4-e2b

# Chain-of-thought control:
#   empty  -> don't send the param. gemma keeps reasoning in a separate field
#             and returns clean content (recommended for gemma).
#   none   -> disable reasoning. REQUIRED for forced-reasoning Qwen3 builds,
#             which otherwise spend the whole budget thinking (empty answer).
LLM_REASONING_EFFORT=

# Max tokens for a single reply (room for reasoning + answer).
LLM_MAX_TOKENS=600

# Host port the web app is published on (docker compose).
WEB_PORT=8080
